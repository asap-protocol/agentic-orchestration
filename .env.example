# NextAuth (GitHub OAuth)
AUTH_SECRET=          # Generate with: npx auth secret
AUTH_GITHUB_ID=       # GitHub OAuth App Client ID
AUTH_GITHUB_SECRET=   # GitHub OAuth App Client Secret
AUTH_URL=             # App URL (e.g. http://localhost:3000)

# Supabase (optional - for data persistence)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cross-Platform Integration (ASAP Protocol)
# See: .cursor/product-specs/prd-cross-platform-integration-agentic.md
NEXT_PUBLIC_ASAP_PROTOCOL_URL=https://asap-protocol.vercel.app    # ASAP Protocol app URL (back-navigation, SSO redirect)

# ASAP registry + revocation (see PRD: .cursor/product-specs/prd-asap-runtime-integration-agentic.md)
# Lite registry (GitHub Pages): https://asap-protocol.github.io/registry/registry.json
# Raw main (GitHub): https://raw.githubusercontent.com/asap-protocol/asap-protocol/main/registry.json
NEXT_PUBLIC_REGISTRY_URL=https://raw.githubusercontent.com/asap-protocol/asap-protocol/main/registry.json
# Revocation list (same host strategy as registry; often raw main revoked_agents.json)
NEXT_PUBLIC_REVOKED_URL=https://raw.githubusercontent.com/asap-protocol/asap-protocol/main/revoked_agents.json
# Optional: ISR revalidate seconds for registry fetch only (default 60, max 3600). Revoked list is always no-store.
NEXT_PUBLIC_REGISTRY_CACHE_SECONDS=60

# Upstash Redis / Vercel Serverless Redis
RATE_LIMIT_CLIENT_IP_HEADER=   # Optional: trusted edge header for rate-limit identity (e.g. CF-Connecting-IP, True-Client-IP)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Some Vercel Redis integrations expose these names:
KV_REST_API_URL=
KV_REST_API_TOKEN=
