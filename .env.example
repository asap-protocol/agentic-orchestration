# NextAuth (GitHub OAuth)
AUTH_SECRET=          # Generate with: npx auth secret
AUTH_GITHUB_ID=       # GitHub OAuth App Client ID
AUTH_GITHUB_SECRET=   # GitHub OAuth App Client Secret
AUTH_URL=             # App URL (e.g. http://localhost:3000)

# Supabase (optional - for data persistence)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cross-Platform Integration (ASAP Protocol)
# See: .cursor/product-specs/prd-cross-platform-integration-agentic.md
NEXT_PUBLIC_ASAP_PROTOCOL_URL=https://asap-protocol.vercel.app    # ASAP Protocol app URL (back-navigation, SSO redirect)
NEXT_PUBLIC_REGISTRY_URL=https://raw.githubusercontent.com/adriannoes/asap-protocol/main/registry.json    # ASAP Agent Registry JSON source
NEXT_PUBLIC_REVOKED_URL=https://raw.githubusercontent.com/adriannoes/asap-protocol/main/revoked_agents.json    # Revoked agents list

# Upstash Redis / Vercel Serverless Redis
RATE_LIMIT_CLIENT_IP_HEADER=   # Optional: trusted edge header for rate-limit identity (e.g. CF-Connecting-IP, True-Client-IP)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Some Vercel Redis integrations expose these names:
KV_REST_API_URL=
KV_REST_API_TOKEN=
